{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "Gateway": {
    "Routes": [
      {
        "RouteId": "user-service-v1",
        "UpstreamPathPattern": "/api/v1/users/{**catch-all}",
        "DownstreamServiceUrl": "http://user-service",
        "DownstreamPathTemplate": "/api/v1/users/{**catch-all}",
        "HttpMethods": [ "GET", "POST", "PUT", "DELETE" ],
        "Enabled": true,
        "TimeoutSeconds": 30,
        "RequireAuthentication": true,
        "RequiredRoles": [],
        "RequiredPolicies": [],
        "ApiVersion": "v1",
        "IsDefaultVersion": false,
        "RateLimit": {
          "PermitLimit": 50,
          "WindowSeconds": 60,
          "PartitionBy": "user"
        },
        "Cache": {
          "Enabled": true,
          "TtlSeconds": 600,
          "VaryByHeaders": [],
          "VaryByQueryParams": [ "page", "pageSize" ]
        }
      },
      {
        "RouteId": "user-service-v2",
        "UpstreamPathPattern": "/api/v2/users/{**catch-all}",
        "DownstreamServiceUrl": "http://user-service",
        "DownstreamPathTemplate": "/api/v2/users/{**catch-all}",
        "HttpMethods": [ "GET", "POST", "PUT", "DELETE" ],
        "Enabled": true,
        "TimeoutSeconds": 30,
        "RequireAuthentication": true,
        "RequiredRoles": [],
        "RequiredPolicies": [],
        "ApiVersion": "v2",
        "IsDefaultVersion": false,
        "RateLimit": {
          "PermitLimit": 100,
          "WindowSeconds": 60,
          "PartitionBy": "user"
        },
        "Cache": {
          "Enabled": true,
          "TtlSeconds": 300,
          "VaryByHeaders": [],
          "VaryByQueryParams": [ "page", "pageSize" ]
        }
      },
      {
        "RouteId": "user-service",
        "UpstreamPathPattern": "/api/users/{**catch-all}",
        "DownstreamServiceUrl": "http://user-service",
        "DownstreamPathTemplate": "/api/v2/users/{**catch-all}",
        "HttpMethods": [ "GET", "POST", "PUT", "DELETE" ],
        "Enabled": true,
        "TimeoutSeconds": 30,
        "RequireAuthentication": true,
        "RequiredRoles": [],
        "RequiredPolicies": [],
        "ApiVersion": "v2",
        "IsDefaultVersion": true,
        "RateLimit": {
          "PermitLimit": 100,
          "WindowSeconds": 60,
          "PartitionBy": "user"
        },
        "Cache": {
          "Enabled": true,
          "TtlSeconds": 300,
          "VaryByHeaders": [],
          "VaryByQueryParams": [ "page", "pageSize" ]
        }
      },
      {
        "RouteId": "order-service",
        "UpstreamPathPattern": "/api/orders/{**catch-all}",
        "DownstreamServiceUrl": "http://order-service",
        "DownstreamPathTemplate": "/api/orders/{**catch-all}",
        "HttpMethods": [ "GET", "POST", "PUT", "DELETE" ],
        "Enabled": true,
        "TimeoutSeconds": 30,
        "RequireAuthentication": true,
        "RequiredRoles": [],
        "RequiredPolicies": [],
        "RateLimit": {
          "PermitLimit": 50,
          "WindowSeconds": 60,
          "PartitionBy": "user"
        },
        "Cache": {
          "Enabled": false
        }
      }
    ],
    "Authentication": {
      "Enabled": true,
      "Authority": "https://auth.example.com",
      "Audience": "api-gateway",
      "ValidateIssuer": true,
      "ValidateAudience": true,
      "ValidateLifetime": true,
      "ClockSkewSeconds": 300
    },
    "Cache": {
      "Enabled": true,
      "ConnectionString": "localhost:6379",
      "DefaultTtlSeconds": 300
    },
    "Resilience": {
      "RetryCount": 3,
      "RetryDelaySeconds": 2,
      "CircuitBreakerFailureRatio": 0.5,
      "CircuitBreakerBreakDurationSeconds": 30,
      "TimeoutSeconds": 30
    },
    "LoadBalancing": {
      "Strategy": "RoundRobin",
      "EnableHealthChecks": true,
      "HealthCheckIntervalSeconds": 30
    },
    "Security": {
      "EnableSecurityHeaders": true,
      "EnableCors": true,
      "AllowedOrigins": [ "http://localhost:3000", "https://app.example.com" ],
      "AllowCredentials": true,
      "MaxRequestBodySizeBytes": 10485760
    },
    "Observability": {
      "EnableDetailedLogging": false,
      "EnableMetrics": true,
      "EnableTracing": true,
      "LogRequestBodies": false,
      "LogResponseBodies": false
    },
    "Services": {
      "DefaultNamespace": "default",
      "user-service": {
        "Url": "http://user-service",
        "Port": "80"
      },
      "order-service": {
        "Url": "http://order-service",
        "Port": "80"
      }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "user-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "user-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://user-service"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://order-service"
          }
        }
      }
    }
  },
  "CacheSettings": {
    "RedisConnectionString": "localhost:6379",
    "MemoryCacheSizeLimitMb": 100,
    "DefaultTtlSeconds": 300,
    "EnableCompression": true,
    "CompressionThresholdBytes": 1024
  },
  "AllowedHosts": "*"
}
