{
  "Application": {
    "Name": "Microservice.Template"
  },
  "Features": {
    "Caching": true,
    "Messaging": false,
    "HealthChecks": true,
    "JwtAuthentication": false,
    "RateLimiting": false,
    "DistributedLocking": false,
    "Sms": false
  },
  "BuildingBlocks": {
    "Caching": {
      "EnableL1Cache": true,
      "EnableL2Cache": false,
      "DefaultTtlSeconds": 300,
      "EnableCompression": true,
      "CompressionThresholdBytes": 1024
    },
    "Messaging": {
      "RabbitMQ": {
        "Host": "localhost",
        "VirtualHost": "/",
        "UserName": "guest",
        "Password": "guest"
      }
    },
    "Security": {
      "TokenOptions": {
        "Audience": "Microservice.Template",
        "Issuer": "Microservice.Template",
        "SecurityKey": "dev-only-security-key-change-before-production-000000000000000000000000",
        "AccessTokenExpiration": 60,
        "RefreshTokenExpiration": 1440
      }
    },
    "HealthChecks": {
      "LivenessEndpoint": "/health/live",
      "ReadinessEndpoint": "/health/ready",
      "StartupEndpoint": "/health/startup",
      "UIEndpoint": "/health/ui",
      "EnableUI": false,
      "EnableCaching": true,
      "EnablePublishers": true
    }
  },
  "AllowedHosts": "*"
}
